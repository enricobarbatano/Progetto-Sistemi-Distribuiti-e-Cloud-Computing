# syntax=docker/dockerfile:1

FROM golang:1.26.4-alpine AS builder

WORKDIR /app

RUN apk add --no-cache git

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build -o /out/client-proxy ./cmd/client-proxy

FROM alpine:3.24

WORKDIR /app

RUN apk add --no-cache ca-certificates wget

COPY --from=builder /out/client-proxy /usr/local/bin/client-proxy

EXPOSE 8080
EXPOSE 8081

ENTRYPOINT ["client-proxy"]